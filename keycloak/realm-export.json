{
  "realm": "tutorial",
  "enabled": true,
  "displayName": "Keycloak Django Tutorial",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard application user"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    }
  ],
  "clients": [
    {
      "clientId": "django-app",
      "name": "Django Tutorial App",
      "enabled": true,
      "publicClient": false,
      "secret": "django-app-secret",
      "redirectUris": [
        "http://localhost:8000/oidc/callback/",
        "http://127.0.0.1:8000/oidc/callback/"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://127.0.0.1:8000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ]
    }
  ]
}
